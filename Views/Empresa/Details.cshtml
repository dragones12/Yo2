@model CBN_Online.Models.Empresa

@{
    ViewData["Title"] = "Detalles de Empresa";
}

<h1>Detalles de Empresa</h1>

<div>
    <h4>@Model.nombre_empresa</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.nombre_empresa)
        </dt>
        <dd class="col-sm-10">
            <strong>@Html.DisplayFor(model => model.nombre_empresa)</strong>
        </dd>
        
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.descripcion)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.descripcion)
        </dd>
        
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.url_logo)
        </dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.url_logo))
            {
                <img src="@Model.url_logo" alt="@Model.nombre_empresa" 
                     style="max-width: 200px; max-height: 200px; border: 1px solid #ddd; border-radius: 4px; padding: 5px;" 
                     onerror="this.onerror=null; this.src='/img/imagen.png';" />
                <br />
                <small class="text-muted">@Model.url_logo</small>
            }
            else
            {
                <span class="text-muted">Sin logo</span>
            }
        </dd>
        
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.created_at)
        </dt>
        <dd class="col-sm-10">
            @Model.created_at.ToString("dd/MM/yyyy HH:mm")
        </dd>
        
        <dt class="col-sm-2">
            Marcas Asociadas
        </dt>
        <dd class="col-sm-10">
            @if (Model.Marcas != null && Model.Marcas.Any())
            {
                <table class="table table-sm table-striped">
                    <thead>
                        <tr>
                            <th>Imagen</th>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>Estado</th>
                            <th>Productos</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var marca in Model.Marcas)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(marca.url_imagen))
                                    {
                                        <img src="@marca.url_imagen" alt="@marca.nombre_marca" 
                                             style="width: 30px; height: 30px; object-fit: cover; border-radius: 5px;"
                                             onerror="this.onerror=null; this.src='/img/imagen.png';" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin imagen</span>
                                    }
                                </td>
                                <td>@marca.nombre_marca</td>
                                <td>
                                    @{
                                        var badgeClass = marca.tipo_marca == "Cerveza" ? "bg-warning" : "bg-info";
                                    }
                                    <span class="badge @badgeClass">@marca.tipo_marca</span>
                                </td>
                                <td>
                                    @if (marca.es_activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>
                                <td>@marca.Productos.Count()</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <span class="text-muted">No tiene marcas asociadas</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.id_empresa" class="btn btn-warning">
        <i class="fas fa-edit"></i> Edit
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back to List
    </a>
</div>
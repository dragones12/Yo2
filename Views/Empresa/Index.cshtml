@model IEnumerable<CBN_Online.Models.Empresa>

@{
    ViewData["Title"] = "Empresas";
}

<h1>Gestión de Empresas</h1>

<!-- ========================================= -->
<!-- NOTIFICACIONES -->
<!-- ========================================= -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle"></i> @TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Info"] != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <i class="fas fa-info-circle"></i> @TempData["Info"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- ========================================= -->
<!-- BOTÓN CREAR -->
<!-- ========================================= -->
<p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Crear Nueva Empresa
    </a>
</p>

<!-- ========================================= -->
<!-- TABLA DE EMPRESAS -->
<!-- ========================================= -->
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Logo</th>
            <th>@Html.DisplayNameFor(model => model.nombre_empresa)</th>
            <th>@Html.DisplayNameFor(model => model.descripcion)</th>
            <th>@Html.DisplayNameFor(model => model.created_at)</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.url_logo))
                    {
                        <img src="@item.url_logo" alt="@item.nombre_empresa" 
                             style="width:50px; height:50px; object-fit:cover; border-radius:5px;" 
                             onerror="this.onerror=null; this.src='/img/imagen.png';" />
                    }
                    else
                    {
                        <span class="text-muted">Sin logo</span>
                    }
                </td>
                <td>
                    <strong>@Html.DisplayFor(modelItem => item.nombre_empresa)</strong>
                </td>
                <td>
                    @{
                        // Limitar descripción a 50 caracteres
                        var descripcionCorta = item.descripcion?.Length > 50 
                            ? item.descripcion.Substring(0, 50) + "..." 
                            : item.descripcion;
                    }
                    @descripcionCorta
                </td>
                <td>@item.created_at.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Edit" asp-route-id="@item.id_empresa" class="btn btn-sm btn-warning" title="Editar">
                            <i class="fas fa-edit"></i> Editar
                        </a>
                        <a asp-action="Details" asp-route-id="@item.id_empresa" class="btn btn-sm btn-info" title="Detalles">
                            <i class="fas fa-info-circle"></i> Detalles
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.id_empresa" class="btn btn-sm btn-danger" title="Eliminar">
                            <i class="fas fa-trash"></i> Eliminar
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- ========================================= -->
<!-- CONTADOR DE REGISTROS -->
<!-- ========================================= -->
<div class="row">
    <div class="col-md-6">
        <p class="text-muted">
            Mostrando <strong>@Model.Count()</strong> empresa(s)
        </p>
    </div>
</div>

<!-- ========================================= -->
<!-- MENSAJE CUANDO NO HAY REGISTROS -->
<!-- ========================================= -->
@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> No hay empresas registradas.
        <a asp-action="Create" class="alert-link">Crear una nueva empresa</a>
    </div>
}
@model IEnumerable<CBN_Online.Models.Marca>

@{
    ViewData["Title"] = "Marcas";
}

<h1>Gestión de Marcas</h1>

<!-- ========================================= -->
<!-- NOTIFICACIONES -->
<!-- ========================================= -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- ========================================= -->
<!-- BOTÓN CREAR -->
<!-- ========================================= -->
<p>
    <a asp-action="Create" class="btn btn-primary">Crear Nueva Marca</a>
</p>

<!-- ========================================= -->
<!-- TABLA DE MARCAS -->
<!-- ========================================= -->
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Imagen</th>
            <th>@Html.DisplayNameFor(model => model.nombre_marca)</th>
            <th>@Html.DisplayNameFor(model => model.tipo_marca)</th>
            <th>@Html.DisplayNameFor(model => model.descripcion)</th>
            <th>@Html.DisplayNameFor(model => model.es_activo)</th>
            <th>@Html.DisplayNameFor(model => model.created_at)</th>
            <th>Empresa</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <!-- Columna de Imagen (igual que Productos) -->
                <td>
                    @if (!string.IsNullOrEmpty(item.url_imagen))
                    {
                        <img src="@item.url_imagen" alt="@item.nombre_marca" 
                             style="width:50px; height:50px; object-fit:cover; border-radius:5px;" 
                             onerror="this.onerror=null; this.src='/img/imagen.png';" />
                    }
                    else
                    {
                        <span class="text-muted">Sin imagen</span>
                    }
                </td>
                
                <td>
                    <strong>@Html.DisplayFor(modelItem => item.nombre_marca)</strong>
                </td>
                <td>
                    @{
                        var badgeClass = item.tipo_marca == "Cerveza" ? "bg-warning" : "bg-info";
                    }
                    <span class="badge @badgeClass">@item.tipo_marca</span>
                </td>
                <td>@Html.DisplayFor(modelItem => item.descripcion)</td>
                <td>
                    @if (item.es_activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactivo</span>
                    }
                </td>
                <td>@item.created_at.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    @if (item.Empresa != null)
                    {
                        @Html.DisplayFor(modelItem => item.Empresa.nombre_empresa)
                    }
                    else
                    {
                        <span class="text-muted">Sin empresa</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.id_marca" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.id_marca" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.id_marca" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- ========================================= -->
<!-- MENSAJE CUANDO NO HAY REGISTROS -->
<!-- ========================================= -->
@if (!Model.Any())
{
    <div class="alert alert-info">
        No hay marcas registradas.
        <a asp-action="Create" class="alert-link">Crear una nueva marca</a>
    </div>
}